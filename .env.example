# --- BearCaptcha environment ---

# Upstream solver API key (required)
TWOCAPTCHA_API_KEY=

# Admin panel secret (required). Use a long, random string in production (>= 16 chars).
ADMIN_SECRET=

# Port the server listens on
PORT=3001

# development | production
NODE_ENV=development

# Comma-separated allow-list of browser origins. Enforced only when NODE_ENV=production.
CORS_ORIGINS=https://bearcaptcha.com
